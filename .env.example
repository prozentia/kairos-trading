# Kairos Trading - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# PostgreSQL
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://kairos:change_me_in_production@localhost:5432/kairos

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_generate_a_random_64_char_string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenRouter (AI Agent)
OPENROUTER_API_KEY=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# Internal token (inter-container auth)
INTERNAL_API_TOKEN=kairos-internal-token-change-me

# Mode
DRY_RUN=true
