# Kairos Trading - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://kairos:change_me_in_production@db:5432/kairos

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT Authentication ─────────────────────────────────────────────
JWT_SECRET=change_me_generate_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Binance ─────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ─── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── OpenRouter (AI Agent) ──────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ─── Firebase (Push Notifications) ──────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# ─── Internal API Token (inter-container auth) ──────────────────────
INTERNAL_API_TOKEN=kairos-internal-token-change-me

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://kairos.prozentia.com

# ─── Engine Configuration ───────────────────────────────────────────
KAIROS_DRY_RUN=true
KAIROS_TESTNET=true
KAIROS_PAIRS=BTCUSDT
KAIROS_STRATEGY_TIMEFRAME=5m
KAIROS_BASE_TIMEFRAME=1m
KAIROS_CAPITAL_PER_PAIR=100.0
KAIROS_MAX_POSITIONS=3
KAIROS_MAX_DAILY_LOSS_PCT=5.0
KAIROS_MAX_DRAWDOWN_PCT=15.0
KAIROS_STRATEGY_TYPE=msb_glissant
KAIROS_LOG_LEVEL=INFO

# ─── Notifier Channel Toggles ──────────────────────────────────────
NOTIFY_TELEGRAM_ENABLED=true
NOTIFY_PUSH_ENABLED=false
NOTIFY_EMAIL_ENABLED=false
NOTIFY_IN_APP_ENABLED=true
